{
  "name": "blipper",
  "version": "0.0.1",
  "description": "The API for the OneConnectivity Portal",
  "author": "Apps Team <team.apps@swisscom.com>",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "prebuild": "rm -rf dist",
    "deps:force-upgrade": "npm-check-updates -u && rm -f package-lock.json && rm -rf node_modules && npm i",
    "format": "prettier --write \"**/*.{ts,json}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "serve": "serve dist",
    "start": "BROWSER=none react-scripts start",
    "build": "react-scripts build"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/tmp": "0.2.6",
    "@typescript-eslint/eslint-plugin": "8.48.0",
    "@typescript-eslint/parser": "8.48.0",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "npm-check-updates": "19.1.2",
    "prettier": "3.6.2",
    "react-scripts": "5.0.1",
    "typescript": "4.9.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
